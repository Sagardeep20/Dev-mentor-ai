# =============================================================================
# DevMentor AI Backend - Environment Configuration
# =============================================================================
# 
# LOCAL DEVELOPMENT:
#   Copy this file to .env and fill in your values
#   DATABASE_URL will default to SQLite (no setup required)
#
# PRODUCTION (Render/Heroku/etc.):
#   Set environment variables in your hosting dashboard
#   DATABASE_URL will be provided by your hosting service (PostgreSQL)
#
# =============================================================================

# =============================================================================
# API KEYS (Required)
# =============================================================================

# Groq API Key - Get one at https://console.groq.com/keys
# This is the GLOBAL key used when a user doesn't provide their own
GROQ_API_KEY=your-groq-api-key-here

# =============================================================================
# MODELS (Usually don't need to change)
# =============================================================================

# Embedding model for code vectorization (for RAG)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chat model for AI responses
CHAT_MODEL=llama-3.3-70b-versatile

# =============================================================================
# DATABASE
# =============================================================================

# LOCAL DEV: SQLite (automatic, no setup)
# DATABASE_URL=sqlite+aiosqlite:///./devmentor.db

# PRODUCTION: PostgreSQL (from your hosting provider)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/devmentordb

# Database connection pool (for PostgreSQL only)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# CHROMADB (Vector Database)
# =============================================================================

# Directory for storing code embeddings
# This is user-isolated (each user's data stored separately)
CHROMA_DIR=./chroma_data

# =============================================================================
# REDIS (Optional - for caching, gracefully degrades if not available)
# =============================================================================

# Uncomment if you have a Redis instance
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 3600 = 1 hour)
REDIS_CACHE_TTL=3600

# =============================================================================
# AUTHENTICATION (Required for production)
# =============================================================================

# JWT Secret - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=change-this-to-a-long-random-secret-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# SECURITY
# =============================================================================

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Set to "production" in production environments
# NODE_ENV=production
